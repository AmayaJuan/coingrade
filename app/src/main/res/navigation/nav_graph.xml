<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.deltaforce.coingrade.ui.home.HomeFragment"
        android:label="CoinGrade">
        <action
            android:id="@+id/action_home_to_capture"
            app:destination="@id/captureFragment" />
        <action
            android:id="@+id/action_home_to_history"
            app:destination="@id/historyFragment" />
    </fragment>

    <fragment
        android:id="@+id/captureFragment"
        android:name="com.deltaforce.coingrade.ui.capture.CaptureFragment"
        android:label="@string/capture_title">
        <action
            android:id="@+id/action_capture_to_verification"
            app:destination="@id/verificationFragment" />
    </fragment>

    <fragment
        android:id="@+id/verificationFragment"
        android:name="com.deltaforce.coingrade.ui.verification.VerificationFragment"
        android:label="@string/verification_title">
        <argument
            android:name="coinName"
            app:argType="string" />
        <action
            android:id="@+id/action_verification_to_result"
            app:destination="@id/resultFragment" />
        <action
            android:id="@+id/action_verification_to_capture"
            app:destination="@id/captureFragment"
            app:popUpTo="@id/captureFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/resultFragment"
        android:name="com.deltaforce.coingrade.ui.result.ResultFragment"
        android:label="Resultado">
        <argument
            android:name="coinName"
            app:argType="string" />
        <argument
            android:name="gradeCode"
            app:argType="string" />
        <argument
            android:name="gradeName"
            app:argType="string" />
        <argument
            android:name="vp"
            app:argType="integer" />
        <action
            android:id="@+id/action_result_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_result_to_history"
            app:destination="@id/historyFragment" />
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.deltaforce.coingrade.ui.history.HistoryFragment"
        android:label="@string/history">
        <action
            android:id="@+id/action_history_to_capture"
            app:destination="@id/captureFragment" />
    </fragment>
</navigation>
