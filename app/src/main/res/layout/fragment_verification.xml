<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D12"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/verification_title"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="8dp"
        android:background="#1A1A2E" />

    <TextView
        android:id="@+id/txt_analyzing_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/analyzing_photos_fmt"
        android:textColor="#8E8E93"
        android:textSize="12sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#1C1C1E"
        app:cardCornerRadius="16dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Sharpness Obverse -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:id="@+id/ic_check_obv"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/checkbox_on_background"
                    app:tint="#A8E6CF" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ic_check_obv"
                    android:layout_marginStart="8dp"
                    android:text="@string/obverse_sharpness"
                    android:textColor="@color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="98%"
                    android:textColor="#8E8E93" />
            </RelativeLayout>

            <!-- Sharpness Reverse -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:id="@+id/ic_check_rev"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/checkbox_on_background"
                    app:tint="#A8E6CF" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ic_check_rev"
                    android:layout_marginStart="8dp"
                    android:text="@string/reverse_sharpness"
                    android:textColor="@color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="95%"
                    android:textColor="#8E8E93" />
            </RelativeLayout>

            <!-- Exposure -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:id="@+id/ic_check_exp"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/checkbox_on_background"
                    app:tint="#A8E6CF" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ic_check_exp"
                    android:layout_marginStart="8dp"
                    android:text="@string/exposure"
                    android:textColor="@color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/balanced"
                    android:textColor="#8E8E93" />
            </RelativeLayout>

            <!-- Coin Detected -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/ic_check_coin"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/checkbox_on_background"
                    app:tint="#A8E6CF" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ic_check_coin"
                    android:layout_marginStart="8dp"
                    android:text="@string/coin_detected"
                    android:textColor="@color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/both_sides"
                    android:textColor="#8E8E93" />
            </RelativeLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/preview_title"
        android:textColor="#8E8E93"
        android:textSize="12sp"
        android:textStyle="bold" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="8dp"
        android:scrollbars="none">
        <LinearLayout
            android:id="@+id/preview_images_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_analyze_ia"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="@string/analyze_ia"
        android:textAllCaps="false"
        app:backgroundTint="#534AB7"
        app:cornerRadius="12dp"
        app:icon="@android:drawable/ic_menu_search" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_retake"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:text="@string/retake_photos"
        android:textAllCaps="false"
        android:textColor="@color/white"
        app:cornerRadius="12dp"
        app:strokeColor="#1C1C1E" />

</LinearLayout>
