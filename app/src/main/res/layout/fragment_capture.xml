<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D12"
    android:padding="12dp">

    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/txt_side_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/photo_obverse"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_flash"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="0dp"
            app:icon="@android:drawable/ic_menu_camera"
            app:iconSize="20dp"
            app:iconTint="@color/white" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/steps_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/header">
        <View android:layout_width="0dp" android:layout_height="3dp" android:layout_weight="1" android:background="#534AB7" android:layout_marginEnd="4dp"/>
        <View android:layout_width="0dp" android:layout_height="3dp" android:layout_weight="1" android:background="#1C1C1E" android:layout_marginEnd="4dp"/>
        <View android:layout_width="0dp" android:layout_height="3dp" android:layout_weight="1" android:background="#1C1C1E" android:layout_marginEnd="4dp"/>
        <View android:layout_width="0dp" android:layout_height="3dp" android:layout_weight="1" android:background="#1C1C1E" />
    </LinearLayout>

    <TextView
        android:id="@+id/txt_side_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#1C1C1E"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:textColor="#534AB7"
        android:textSize="11sp"
        android:text="Anverso - 0 / 3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/steps_container" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_layout_name"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/coin_name_hint"
        app:boxBackgroundColor="#1C1C1E"
        app:boxStrokeWidth="0dp"
        app:hintTextColor="#8E8E93"
        android:textColorHint="#8E8E93"
        app:layout_constraintTop_toBottomOf="@id/txt_side_count">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_coin_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="10dp"
            android:inputType="text"
            android:textColor="@color/white"
            android:textSize="14sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <FrameLayout
        android:id="@+id/preview_round_container"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/input_layout_name">

        <androidx.camera.view.PreviewView
            android:id="@+id/preview_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <View
            android:id="@+id/ring_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/coin_overlay_border" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="EN VIVO\n-\ntoca"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="9sp"
            android:textStyle="bold" />
    </FrameLayout>

    <TextView
        android:id="@+id/txt_prompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#1C1C1E"
        android:padding="10dp"
        android:drawablePadding="8dp"
        android:text="@string/open_camera_prompt"
        android:textColor="@color/white"
        android:textSize="12sp"
        app:drawableStartCompat="@android:drawable/ic_menu_camera"
        app:layout_constraintTop_toBottomOf="@id/preview_round_container" />

    <TextView
        android:id="@+id/txt_scale_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="@string/scale_info"
        android:textColor="#8E8E93"
        android:textSize="10sp"
        app:layout_constraintTop_toBottomOf="@id/txt_prompt" />

    <LinearLayout
        android:id="@+id/slots_container"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/txt_scale_info">
        <FrameLayout android:id="@+id/slot1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="6dp" android:background="@drawable/bg_slot_empty"><ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@android:drawable/ic_input_add"/></FrameLayout>
        <FrameLayout android:id="@+id/slot2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="6dp" android:background="@drawable/bg_slot_empty"><ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@android:drawable/ic_input_add"/></FrameLayout>
        <FrameLayout android:id="@+id/slot3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_slot_empty"><ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@android:drawable/ic_input_add"/></FrameLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/feedback_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="#1C1C1E"
        app:cardCornerRadius="12dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/slots_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/feedback_title"
                android:textColor="#8E8E93"
                android:textSize="10sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView android:id="@+id/ic_check_light" android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/checkbox_on_background" app:tint="#A8E6CF"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="@string/feedback_lighting" android:textColor="@color/white" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/optimum" android:textColor="#8E8E93" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView android:id="@+id/ic_check_focus" android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/checkbox_on_background" app:tint="#A8E6CF"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="@string/feedback_focus" android:textColor="@color/white" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/sharp" android:textColor="#8E8E93" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView android:id="@+id/ic_check_framing" android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/btn_dialog" app:tint="#FFD700"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="@string/feedback_framing" android:textColor="@color/white" android:textSize="12sp"/>
                <TextView android:id="@+id/txt_framing_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/center_coin" android:textColor="#8E8E93" android:textSize="12sp"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_capture"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:text="@string/waiting_framing"
        android:textAllCaps="false"
        app:backgroundTint="#1C1C1E"
        app:cornerRadius="10dp"
        app:layout_constraintTop_toBottomOf="@id/feedback_card"
        app:layout_constraintBottom_toTopOf="@id/btn_restart"
        app:layout_constraintVertical_bias="0"/>

    <TextView
        android:id="@+id/btn_restart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="@string/restart_photos"
        android:textColor="#FF3B30"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>